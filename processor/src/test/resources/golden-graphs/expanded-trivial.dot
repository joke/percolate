digraph "com.example.expanded.trivial.PersonMapper" {
  subgraph "cluster_map(Person)" {
    label="map(Person)";
    "map(Person)::src[person]::Person" [label="src[person]", shape="box"];
    "map(Person)::src[person.lastName]::?" [label="src[person.lastName]", shape="box"];
    "map(Person)::src[person.first]::?" [label="src[person.first]", shape="box"];
    "map(Person)::tgt[lastName]::?" [label="tgt[lastName]", shape="oval"];
    "map(Person)::tgt[firstName]::?" [label="tgt[firstName]", shape="oval"];
    "map(Person)::tgt[]::Human" [label="tgt[]", shape="oval"];
  }
    "map(Person)::src[person]::Person" -> "map(Person)::src[person.lastName]::?" [label="SEED | ∞ | directive", style="solid"];
    "map(Person)::src[person]::Person" -> "map(Person)::src[person.first]::?" [label="SEED | ∞ | directive", style="solid"];
    "map(Person)::src[person.lastName]::?" -> "map(Person)::tgt[lastName]::?" [label="SEED | ∞ | directive", style="solid"];
    "map(Person)::src[person.first]::?" -> "map(Person)::tgt[firstName]::?" [label="SEED | ∞ | directive", style="solid"];
    "map(Person)::tgt[lastName]::?" -> "map(Person)::tgt[]::Human" [label="SEED | ∞", style="solid"];
    "map(Person)::tgt[firstName]::?" -> "map(Person)::tgt[]::Human" [label="SEED | ∞", style="solid"];
    "map(Person)::src[person]::Person" -> "map(Person)::src[person→getLastName()]::String" [label="REALISED | 1 | GetterRead", style="dashed"];
    "map(Person)::src[person]::Person" -> "map(Person)::src[person→getFirst()]::String" [label="REALISED | 1 | GetterRead", style="dashed"];
    "map(Person)::src[person.lastName]::?" -> "map(Person)::src[person→getLastName()]::String" [label="MARKER | 0", style="dotted"];
    "map(Person)::src[person.first]::?" -> "map(Person)::src[person→getFirst()]::String" [label="MARKER | 0", style="dotted"];
    "map(Person)::src[person→getLastName()]::String" -> "map(Person)::tgt[lastName]::?" [label="REALISED | 0 | DirectAssign", style="dashed"];
    "map(Person)::src[person→getFirst()]::String" -> "map(Person)::tgt[firstName]::?" [label="REALISED | 0 | DirectAssign", style="dashed"];
}
