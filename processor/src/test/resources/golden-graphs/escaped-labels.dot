digraph "com.example.EscapedLabels" {
  subgraph "cluster_map(Person)" {
    label="map(Person)";
    "map(Person)::src[name]::Person" [label="src[name]", shape=box];
    "map(Person)::src[name]::?" [label="src[name]", shape=box];
    "map(Person)::tgt[]::void" [label="tgt[]", shape=oval];
  }
    "map(Person)::src[name]::Person" -> "map(Person)::src[name]::?" [label="1", style=bold];
    "map(Person)::src[name]::?" -> "map(Person)::tgt[]::void" [label="1", style=bold];
}
